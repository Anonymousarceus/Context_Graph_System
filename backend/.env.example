# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS - set this when deploying)
# Development: http://localhost:5173
# Production: https://context-graph-frontend.onrender.com
FRONTEND_URL=http://localhost:5173

# MongoDB Database (MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/context_graph?appName=Cluster0

# Gemini API (Get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Data Source Path (relative to backend folder)
DATA_SOURCE_PATH=../../sap-o2c-data

# Logging
LOG_LEVEL=info
